@page "/proveedores"
@using AbarrotesPOS.Data
@using AbarrotesPOS.Shared
@using AbarrotesPOS.App.Components.Base
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer
@inherits CrudBaseComponent<Proveedor>

<PageTitle>Proveedores</PageTitle>

<h1>Administración de Proveedores</h1>
<p>Gestiona los proveedores que surten productos a la tienda.</p>

@if (!string.IsNullOrEmpty(mensajeError))
{
    <div class="alert alert-danger alert-dismissible">
        <i class="bi bi-exclamation-circle-fill me-2"></i>@mensajeError
        <button type="button" class="btn-close" @onclick="() => mensajeError = string.Empty"></button>
    </div>
}

<button class="btn btn-primary mb-3" @onclick="AbrirModalParaCrear">
    <i class="bi bi-plus-circle-fill"></i> Nuevo Proveedor
</button>

@if (listaEntidades == null)
{
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Cargando...</span>
    </div>
}
else
{
    <table class="table table-striped table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>RFC</th>
                <th>Nombre</th>
                <th>Contacto</th>
                <th>Teléfono</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var proveedor in listaEntidades)
            {
                <tr>
                    <td><span class="badge bg-secondary">@proveedor.Rfc</span></td>
                    <td>@proveedor.Nombre</td>
                    <td>@proveedor.Contacto</td>
                    <td>@proveedor.Telefono</td>
                    <td>
                        <button class="btn btn-sm btn-warning me-2" @onclick="() => AbrirModalParaEditar(proveedor)">
                            <i class="bi bi-pencil-fill"></i> Editar
                        </button>
                        <button class="btn btn-sm btn-danger" @onclick="() => Eliminar(proveedor)">
                            <i class="bi bi-trash3-fill"></i> Eliminar
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (mostrarModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(entidadActual.Id == 0 ? "Nuevo Proveedor" : "Editar Proveedor")</h5>
                    <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                </div>
                <EditForm Model="entidadActual" OnValidSubmit="Guardar">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        @if (!string.IsNullOrEmpty(mensajeError))
                        {
                            <div class="alert alert-danger">@mensajeError</div>
                        }
                        <ValidationSummary class="text-danger mb-3" />
                        <div class="mb-3">
                            <label class="form-label">RFC</label>
                            <InputText class="form-control" @bind-Value="entidadActual.Rfc" placeholder="Ej: AAAA000000XXX" />
                            <ValidationMessage For="() => entidadActual.Rfc" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Nombre del Proveedor *</label>
                            <InputText class="form-control" @bind-Value="entidadActual.Nombre" />
                            <ValidationMessage For="() => entidadActual.Nombre" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Persona de Contacto</label>
                            <InputText class="form-control" @bind-Value="entidadActual.Contacto" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Teléfono</label>
                            <InputText class="form-control" @bind-Value="entidadActual.Telefono" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                        <button type="submit" class="btn btn-primary">Guardar</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    // Solo necesitamos implementar cómo clonar un Proveedor.
    // CargarDatos, AbrirModal, Guardar, Eliminar vienen de CrudBaseComponent<T>.
    protected override Proveedor CloneEntidad(Proveedor original) => new()
    {
        Id = original.Id,
        Rfc = original.Rfc,
        Nombre = original.Nombre,
        Contacto = original.Contacto,
        Telefono = original.Telefono
    };
}