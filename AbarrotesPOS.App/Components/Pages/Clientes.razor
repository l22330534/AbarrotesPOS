@page "/clientes"
@using AbarrotesPOS.Data
@using AbarrotesPOS.Shared
@using Microsoft.EntityFrameworkCore
@inject AppDbContext DbContext
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Clientes y Fidelidad</PageTitle>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Directorio de Clientes</h1>
        <button class="btn btn-primary" @onclick="AbrirModalCrear">
            <i class="bi bi-person-plus-fill"></i> Nuevo Cliente
        </button>
    </div>

    @if (listaClientes == null)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else if (!listaClientes.Any())
    {
        <div class="alert alert-info shadow-sm">
            <i class="bi bi-info-circle-fill me-2"></i> No hay clientes registrados aún. ¡Registra al primero para empezar el programa de fidelidad!
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table table-striped table-hover mb-0 align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Nombre</th>
                            <th>Contacto</th>
                            <th>Puntos Acumulados</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in listaClientes)
                        {
                            <tr>
                                <td class="fw-bold">@c.Nombre</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(c.Telefono))
                                    {
                                        <div><i class="bi bi-telephone-fill text-muted small me-1"></i> @c.Telefono</div>
                                    }
                                    @if (!string.IsNullOrEmpty(c.Correo))
                                    {
                                        <div class="text-muted small"><i class="bi bi-envelope-fill me-1"></i> @c.Correo</div>
                                    }
                                </td>
                                <td>
                                    <!-- CORRECCIÓN: Usamos .Puntos en lugar de .PuntosAcumulados -->
                                    <span class="badge bg-warning text-dark fs-6 rounded-pill border border-warning">
                                        <i class="bi bi-star-fill text-white"></i> @c.Puntos pts
                                    </span>
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => AbrirModalEditar(c)">
                                        <i class="bi bi-pencil-fill"></i>
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => Eliminar(c)">
                                        <i class="bi bi-trash3-fill"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<!-- Modal Cliente -->
@if (mostrarModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-light">
                    <h5 class="modal-title">@(clienteActual.Id == 0 ? "Nuevo Cliente" : "Editar Cliente")</h5>
                    <button class="btn-close" @onclick="() => mostrarModal = false"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="clienteActual" OnValidSubmit="Guardar">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Nombre Completo</label>
                            <InputText @bind-Value="clienteActual.Nombre" class="form-control" placeholder="Ej. Juan Pérez" />
                            <ValidationMessage For="() => clienteActual.Nombre" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Teléfono</label>
                                <InputText @bind-Value="clienteActual.Telefono" class="form-control" placeholder="Ej. 555-1234" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Puntos (Ajuste)</label>
                                <!-- CORRECCIÓN: Usamos .Puntos -->
                                <InputNumber @bind-Value="clienteActual.Puntos" class="form-control" />
                                <div class="form-text small">Editar solo si es necesario.</div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Correo Electrónico</label>
                            <InputText @bind-Value="clienteActual.Correo" class="form-control" placeholder="cliente@email.com" />
                        </div>

                        <div class="modal-footer px-0 pb-0 border-top-0">
                            <button type="button" class="btn btn-secondary me-2" @onclick="() => mostrarModal = false">Cancelar</button>
                            <button type="submit" class="btn btn-primary">Guardar</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Cliente>? listaClientes;
    private Cliente clienteActual = new();
    private bool mostrarModal = false;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        // CORRECCIÓN: Ordenamos por .Puntos
        listaClientes = await DbContext.Clientes.OrderByDescending(c => c.Puntos).ToListAsync();
    }

    private void AbrirModalCrear()
    {
        clienteActual = new Cliente();
        mostrarModal = true;
    }

    private void AbrirModalEditar(Cliente c)
    {
        // CORRECCIÓN: Copiamos .Puntos
        clienteActual = new Cliente
        {
            Id = c.Id,
            Nombre = c.Nombre,
            Telefono = c.Telefono,
            Correo = c.Correo,
            Puntos = c.Puntos
        };
        mostrarModal = true;
    }

    private async Task Guardar()
    {
        if (clienteActual.Id == 0)
        {
            DbContext.Clientes.Add(clienteActual);
        }
        else
        {
            var clienteEnDb = await DbContext.Clientes.FindAsync(clienteActual.Id);
            if (clienteEnDb != null)
            {
                clienteEnDb.Nombre = clienteActual.Nombre;
                clienteEnDb.Telefono = clienteActual.Telefono;
                clienteEnDb.Correo = clienteActual.Correo;
                // CORRECCIÓN: Asignamos .Puntos
                clienteEnDb.Puntos = clienteActual.Puntos;
            }
        }

        await DbContext.SaveChangesAsync();
        await CargarDatos();
        mostrarModal = false;
    }

    private async Task Eliminar(Cliente c)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"¿Estás seguro de borrar a {c.Nombre}? Se perderán sus puntos."))
        {
            DbContext.Clientes.Remove(c);
            await DbContext.SaveChangesAsync();
            await CargarDatos();
        }
    }
}