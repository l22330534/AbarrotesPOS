@page "/puntodeventa"
@using AbarrotesPOS.Data
@using AbarrotesPOS.Data.Repositories
@using AbarrotesPOS.Shared
@using AbarrotesPOS.Shared.DTOs
@using AbarrotesPOS.Services
@using Microsoft.EntityFrameworkCore
@inject AppDbContext DbContext
@inject IProductoRepository ProductoRepo
@inject UserSessionService UserSession
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Punto de Venta</PageTitle>

<div class="container-fluid">
    <div class="row">

        <!-- Panel Izquierdo: Buscador de Productos -->
        <div class="col-md-7">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-search"></i> Catálogo</h5>
                </div>
                <div class="card-body">
                    <div class="input-group mb-3">
                        <span class="input-group-text"><i class="bi bi-upc-scan"></i></span>
                        <input type="text"
                               class="form-control"
                               placeholder="Buscar producto por nombre o código de barras..."
                               value="@terminoBusqueda"
                               @oninput="BuscarProductos" />
                    </div>

                    <div class="table-responsive" style="height: 500px; overflow-y: auto;">
                        <table class="table table-hover align-middle">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>Producto</th>
                                    <th>Precio</th>
                                    <th>Stock</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!productosEncontrados.Any())
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-4">
                                            <i class="bi bi-search me-2"></i>
                                            Escribe para buscar productos
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var prod in productosEncontrados)
                                    {
                                        bool sinStock = prod.Stock <= 0;
                                        <tr class="@(sinStock ? "table-secondary" : "")">
                                            <td>
                                                <div class="fw-bold">@prod.Nombre</div>
                                                <small class="text-muted font-monospace">@prod.CodigoBarras</small>
                                            </td>
                                            <td class="text-primary fw-bold">
                                                @prod.PrecioVenta.ToString("C")
                                            </td>
                                            <td>
                                                <span class="badge @(prod.Stock > 0 ? "bg-success" : "bg-danger")">
                                                    @prod.Stock
                                                </span>
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-outline-primary"
                                                        disabled="@sinStock"
                                                        @onclick="() => AgregarAlCarrito(prod)">
                                                    <i class="bi bi-plus-lg"></i> Agregar
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Panel Derecho: Carrito y Cliente -->
        <div class="col-md-5">
            <div class="card shadow h-100 border-0">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-receipt me-2"></i>Ticket de Venta</h5>
                    <button class="btn btn-sm btn-danger" @onclick="LimpiarCarrito">
                        <i class="bi bi-trash3 me-1"></i> Limpiar
                    </button>
                </div>
                <div class="card-body d-flex flex-column">

                    <!-- Programa de Fidelidad -->
                    <div class="mb-3 p-3 bg-light rounded border border-warning">
                        <label class="small text-muted fw-bold mb-1">
                            <i class="bi bi-star-fill text-warning"></i> PROGRAMA DE FIDELIDAD
                        </label>
                        <div class="input-group">
                            <select class="form-select" @bind="clienteSeleccionadoId">
                                <option value="">-- Cliente Casual (Sin puntos) --</option>
                                @foreach (var c in listaClientes ?? new())
                                {
                                    <option value="@c.Id">@c.Nombre (Tiene: @c.Puntos pts)</option>
                                }
                            </select>
                            <a href="clientes" class="btn btn-outline-secondary" title="Nuevo Cliente">
                                <i class="bi bi-person-plus"></i>
                            </a>
                        </div>
                        @if (puntosGanados > 0 && clienteSeleccionadoId != null)
                        {
                            <div class="mt-2 text-success small fw-bold text-center">
                                <i class="bi bi-gift-fill"></i> ¡Esta compra generará @puntosGanados puntos!
                            </div>
                        }
                    </div>

                    <!-- Lista del Carrito -->
                    <div class="flex-grow-1 overflow-auto mb-3 border-top border-bottom py-2"
                         style="max-height: 350px;">
                        @if (!carrito.Any())
                        {
                            <div class="text-center text-muted mt-5">
                                <i class="bi bi-cart fs-1"></i>
                                <p class="mt-2">Carrito vacío</p>
                            </div>
                        }
                        else
                        {
                            <ul class="list-group list-group-flush">
                                @foreach (var item in carrito)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                        <div class="me-2" style="flex:1">
                                            <div class="fw-bold">@item.NombreProducto</div>
                                            <small class="text-muted">@item.PrecioVenta.ToString("C") x</small>
                                            <div class="btn-group btn-group-sm ms-2">
                                                <button class="btn btn-outline-secondary py-0"
                                                        @onclick="() => CambiarCantidad(item, -1)">
                                                    −
                                                </button>
                                                <span class="btn btn-light border py-0 disabled text-dark"
                                                      style="width:35px">@item.Cantidad</span>
                                                <button class="btn btn-outline-secondary py-0"
                                                        @onclick="() => CambiarCantidad(item, 1)">
                                                    +
                                                </button>
                                            </div>
                                        </div>
                                        <div class="text-end">
                                            <div class="fw-bold text-success">
                                                @((item.Cantidad * item.PrecioVenta).ToString("C"))
                                            </div>
                                            <button class="btn btn-link text-danger p-0 small text-decoration-none"
                                                    @onclick="() => RemoverItem(item)">
                                                Quitar
                                            </button>
                                        </div>
                                    </li>
                                }
                            </ul>
                        }
                    </div>

                    <!-- Totales y Cobro -->
                    <div class="mt-auto">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="h4 m-0">Total:</span>
                            <span class="h2 fw-bold text-success m-0">@Total.ToString("C")</span>
                        </div>
                        <button class="btn btn-success btn-lg w-100 py-3 fw-bold shadow"
                                disabled="@(!carrito.Any())"
                                @onclick="ProcesarVenta">
                            <i class="bi bi-cash-coin me-2"></i> COBRAR
                        </button>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

@code {

    // ─── Clase interna del carrito ───────────────────────────────────────────
    // Antes el carrito usaba VentaDetalle directamente, lo que cargaba
    // la entidad completa con todas sus navegaciones. Ahora usamos una
    // clase liviana solo con lo que el carrito necesita mostrar.
    private class ItemCarrito
    {
        public int ProductoId { get; set; }
        public string NombreProducto { get; set; } = string.Empty;
        public decimal PrecioVenta { get; set; }
        public int Cantidad { get; set; }
        public int StockDisponible { get; set; }
    }

    // ─── Estado ──────────────────────────────────────────────────────────────
    private string terminoBusqueda = string.Empty;
    private List<ProductoDto> productosEncontrados = new();
    private List<ItemCarrito> carrito = new();
    private List<Cliente>? listaClientes;
    private int? clienteSeleccionadoId = null;

    private decimal Total => carrito.Sum(x => x.Cantidad * x.PrecioVenta);
    private int puntosGanados => (int)(Total / 10);

    // ─── Ciclo de vida ───────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        listaClientes = await DbContext.Clientes.OrderBy(c => c.Nombre).ToListAsync();
    }

    // ─── Búsqueda con caché via ProductoRepository ───────────────────────────

    private async Task BuscarProductos(ChangeEventArgs e)
    {
        terminoBusqueda = e.Value?.ToString() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(terminoBusqueda))
        {
            productosEncontrados.Clear();
            return;
        }

        // SearchAsync usa IMemoryCache: si el mismo término se buscó en los
        // últimos 5 minutos, devuelve el resultado sin ir a la BD.
        productosEncontrados = await ProductoRepo.SearchAsync(terminoBusqueda, take: 10);
    }

    // ─── Carrito ─────────────────────────────────────────────────────────────

    private void AgregarAlCarrito(ProductoDto prod)
    {
        var item = carrito.FirstOrDefault(x => x.ProductoId == prod.Id);
        if (item != null)
        {
            if (item.Cantidad < item.StockDisponible)
                item.Cantidad++;
        }
        else
        {
            carrito.Add(new ItemCarrito
            {
                ProductoId = prod.Id,
                NombreProducto = prod.Nombre,
                PrecioVenta = prod.PrecioVenta,
                Cantidad = 1,
                StockDisponible = prod.Stock
            });
        }
    }

    private void CambiarCantidad(ItemCarrito item, int cambio)
    {
        if (cambio > 0 && item.Cantidad < item.StockDisponible)
            item.Cantidad++;
        else if (cambio < 0)
        {
            if (item.Cantidad > 1) item.Cantidad--;
            else RemoverItem(item);
        }
    }

    private void RemoverItem(ItemCarrito item) => carrito.Remove(item);

    private void LimpiarCarrito()
    {
        carrito.Clear();
        terminoBusqueda = string.Empty;
        productosEncontrados.Clear();
        clienteSeleccionadoId = null;
    }

    // ─── Procesar Venta ──────────────────────────────────────────────────────

    private async Task ProcesarVenta()
    {
        if (!carrito.Any()) return;

        using var transaction = await DbContext.Database.BeginTransactionAsync();
        try
        {
            // 1. Crear la venta
            var nuevaVenta = new Venta
            {
                FechaVenta = DateTime.Now,
                Total = Total,
                UsuarioId = UserSession.UsuarioActual?.Id ?? 1,
                ClienteId = (clienteSeleccionadoId.HasValue && clienteSeleccionadoId > 0)
                             ? clienteSeleccionadoId : null
            };
            DbContext.Ventas.Add(nuevaVenta);
            await DbContext.SaveChangesAsync();

            // 2. Guardar detalles y descontar stock
            foreach (var item in carrito)
            {
                DbContext.VentaDetalles.Add(new VentaDetalle
                {
                    VentaId = nuevaVenta.Id,
                    ProductoId = item.ProductoId,
                    PrecioVenta = item.PrecioVenta,
                    Cantidad = item.Cantidad
                });

                var prodDb = await DbContext.Productos.FindAsync(item.ProductoId);
                if (prodDb != null) prodDb.Stock -= item.Cantidad;
            }

            // 3. Sumar puntos de fidelidad
            if (clienteSeleccionadoId.HasValue && clienteSeleccionadoId > 0)
            {
                var clienteDb = await DbContext.Clientes.FindAsync(clienteSeleccionadoId.Value);
                if (clienteDb != null) clienteDb.Puntos += puntosGanados;
            }

            await DbContext.SaveChangesAsync();
            await transaction.CommitAsync();

            int puntosGenerados = puntosGanados;
            LimpiarCarrito();

            string msg = "¡Venta exitosa!";
            if (puntosGenerados > 0) msg += $" El cliente ganó {puntosGenerados} puntos.";
            await JS.InvokeVoidAsync("alert", msg);
        }
        catch (Exception ex)
        {
            await transaction.RollbackAsync();
            await JS.InvokeVoidAsync("alert", "Error al procesar: " + ex.Message);
        }
    }
}