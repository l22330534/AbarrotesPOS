@page "/inicio"
@using AbarrotesPOS.Services
@inject NavigationManager NavManager
@inject UserSessionService UserSession
@rendermode InteractiveServer

<PageTitle>Inicio</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
    <div>
        <h1 class="m-0">Panel Principal</h1>
        <small class="text-muted">
            Bienvenido, <strong>@(UserSession.UsuarioActual?.NombreCompleto ?? "Usuario")</strong>
            (@(UserSession.UsuarioActual?.Rol?.Nombre ?? "Invitado"))
        </small>
    </div>

    <!-- Botón Salir: Limpia la sesión y redirige -->
    <button class="btn btn-outline-danger" @onclick="CerrarSesion">
        <i class="bi bi-box-arrow-right"></i> Cerrar Sesión
    </button>
</div>

<div class="card shadow-sm">
    <div class="card-body text-center py-5">
        <h3 class="text-muted mb-3">Espacio de Trabajo</h3>

        @if (UserSession.EsAdmin)
        {
            <div class="alert alert-info d-inline-block">
                <i class="bi bi-shield-fill"></i> Modo Administrador Activado
            </div>
            <p class="mt-3">Tienes acceso total al sistema de inventarios y usuarios.</p>
        }
        else
        {
            <div class="alert alert-success d-inline-block">
                <i class="bi bi-cart-check-fill"></i> Modo Cajero Activado
            </div>
            <p class="mt-3">Listo para realizar ventas. (Próximamente)</p>
        }

        <div class="mt-4">
            <i class="bi bi-laptop display-1 text-secondary opacity-25"></i>
        </div>
    </div>
</div>

@code {
    private void CerrarSesion()
    {
        UserSession.CerrarSesion();
        NavManager.NavigateTo("/", forceLoad: true);
    }
}