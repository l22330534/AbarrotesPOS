@page "/categorias"
@using AbarrotesPOS.Data
@using AbarrotesPOS.Shared
@using Microsoft.EntityFrameworkCore @* <-- ¡ESTA ES LA LÍNEA QUE SOLUCIONA EL ERROR! *@
@inject AppDbContext DbContext
@rendermode InteractiveServer

<PageTitle>Categorías</PageTitle>

<h1>Administración de Categorías</h1>
<p>Aquí puedes ver, agregar, editar y eliminar las categorías de productos.</p>

<button class="btn btn-primary mb-3" @onclick="AbrirModalParaCrear">
    <i class="bi bi-plus-circle-fill"></i> Nueva Categoría
</button>

@if (listaCategorias == null)
{
    <p><em>Cargando categorías...</em></p>
}
else
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Nombre</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var categoria in listaCategorias)
            {
                <tr>
                    <td>@categoria.Id</td>
                    <td>@categoria.Nombre</td>
                    <td>
                        <button class="btn btn-sm btn-warning" @onclick="() => AbrirModalParaEditar(categoria)">
                            <i class="bi bi-pencil-fill"></i> Editar
                        </button>
                        <button class="btn btn-sm btn-danger" @onclick="() => EliminarCategoria(categoria)">
                            <i class="bi bi-trash3-fill"></i> Eliminar
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<!-- Modal para Crear/Editar Categoría -->
@if (mostrarModal)
{
    <div class="modal fade show" tabindex="-1" style="display: block;">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(categoriaActual.Id == 0 ? "Nueva Categoría" : "Editar Categoría")</h5>
                    <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="categoriaActual" OnValidSubmit="GuardarCategoria">
                        <DataAnnotationsValidator />
                        <div class="mb-3">
                            <label for="nombre" class="form-label">Nombre de la Categoría</label>
                            <InputText id="nombre" class="form-control" @bind-Value="categoriaActual.Nombre" />
                            <ValidationMessage For="() => categoriaActual.Nombre" />
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                            <button type="submit" class="btn btn-primary">Guardar</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}


@code {
    private List<Categoria>? listaCategorias;
    private Categoria categoriaActual = new();
    private bool mostrarModal = false;

    protected override async Task OnInitializedAsync()
    {
        await CargarCategorias();
    }

    private async Task CargarCategorias()
    {
        listaCategorias = await DbContext.Categorias.OrderBy(c => c.Nombre).ToListAsync();
    }

    private void AbrirModalParaCrear()
    {
        categoriaActual = new Categoria();
        mostrarModal = true;
    }

    private void AbrirModalParaEditar(Categoria categoria)
    {
        // Clonamos el objeto para no modificar la lista directamente hasta guardar
        categoriaActual = new Categoria { Id = categoria.Id, Nombre = categoria.Nombre };
        mostrarModal = true;
    }

    private void CerrarModal()
    {
        mostrarModal = false;
    }

    private async Task GuardarCategoria()
    {
        if (string.IsNullOrWhiteSpace(categoriaActual.Nombre))
        {
            // Opcional: Podrías mostrar un mensaje de error al usuario aquí
            return;
        }

        if (categoriaActual.Id == 0)
        {
            // Es una nueva categoría
            DbContext.Categorias.Add(categoriaActual);
        }
        else
        {
            // Es una categoría existente
            var categoriaEnDb = await DbContext.Categorias.FindAsync(categoriaActual.Id);
            if (categoriaEnDb != null)
            {
                categoriaEnDb.Nombre = categoriaActual.Nombre;
            }
        }

        await DbContext.SaveChangesAsync();
        await CargarCategorias();
        CerrarModal();
    }

    private async Task EliminarCategoria(Categoria categoria)
    {
        // Aquí podrías agregar una confirmación si lo deseas
        DbContext.Categorias.Remove(categoria);
        await DbContext.SaveChangesAsync();
        await CargarCategorias();
    }
}

