@page "/categorias"
@using AbarrotesPOS.Data
@using AbarrotesPOS.Shared
@using AbarrotesPOS.App.Components.Base
@using Microsoft.EntityFrameworkCore
@rendermode InteractiveServer
@inherits CrudBaseComponent<Categoria>

<PageTitle>Categorías</PageTitle>

<div class="container">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="mb-0">Administración de Categorías</h1>
            <p class="text-muted mb-0">Aquí puedes ver, agregar, editar y eliminar las categorías de productos.</p>
        </div>
        <button class="btn btn-primary" @onclick="AbrirModalParaCrear">
            <i class="bi bi-plus-circle-fill"></i> Nueva Categoría
        </button>
    </div>

    @if (!string.IsNullOrEmpty(mensajeError))
    {
        <div class="alert alert-danger alert-dismissible shadow-sm">
            <i class="bi bi-exclamation-circle-fill me-2"></i>@mensajeError
            <button type="button" class="btn-close" @onclick="() => mensajeError = string.Empty"></button>
        </div>
    }

    @if (listaEntidades == null)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }
    else if (!listaEntidades.Any())
    {
        <div class="text-center text-muted my-5">
            <i class="bi bi-tag fs-1"></i>
            <p class="mt-2">No hay categorías registradas. ¡Crea la primera!</p>
        </div>
    }
    else
    {
        <table class="table table-striped table-hover align-middle shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th style="width: 80px;">ID</th>
                    <th>Nombre</th>
                    <th style="width: 160px;" class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var categoria in listaEntidades)
                {
                    <tr>
                        <td class="text-muted small">#@categoria.Id</td>
                        <td class="fw-semibold">@categoria.Nombre</td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-warning me-1"
                                    @onclick="() => AbrirModalParaEditar(categoria)">
                                <i class="bi bi-pencil-fill"></i> Editar
                            </button>
                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="() => Eliminar(categoria)">
                                <i class="bi bi-trash3-fill"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

</div>

@if (mostrarModal)
{
    <div class="modal fade show" tabindex="-1" style="display: block; background: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">
                        <i class="bi bi-@(entidadActual.Id == 0 ? "plus-circle" : "pencil-square") me-2"></i>
                        @(entidadActual.Id == 0 ? "Nueva Categoría" : "Editar Categoría")
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModal"></button>
                </div>
                <EditForm Model="entidadActual" OnValidSubmit="Guardar">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        @if (!string.IsNullOrEmpty(mensajeError))
                        {
                            <div class="alert alert-danger">@mensajeError</div>
                        }
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Nombre de la Categoría</label>
                            <InputText class="form-control" @bind-Value="entidadActual.Nombre"
                                       placeholder="Ej: Lácteos, Bebidas, Limpieza..." />
                            <ValidationMessage For="() => entidadActual.Nombre" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CerrarModal">
                            <i class="bi bi-x-circle me-1"></i> Cancelar
                        </button>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i> Guardar
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    protected override Categoria CloneEntidad(Categoria original) => new()
    {
        Id = original.Id,
        Nombre = original.Nombre
    };
}